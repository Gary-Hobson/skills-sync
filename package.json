{
  "name": "@garyhobson/skills-sync",
  "version": "0.3.4",
  "description": "跨设备、跨工作区统一管理和同步 AI Agent skills 的 CLI 工具",
  "type": "module",
  "bin": {
    "skills-sync": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && rollup -c rollup.config.mjs && chmod +x dist/index.js",
    "build:types": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "skills",
    "sync",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gary-Hobson/skills-sync.git"
  },
  "homepage": "https://github.com/Gary-Hobson/skills-sync#readme",
  "bugs": {
    "url": "https://github.com/Gary-Hobson/skills-sync/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.5",
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.4.0",
    "commander": "^14.0.3",
    "diff": "^7.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
